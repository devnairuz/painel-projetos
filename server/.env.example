# Porta da API
PORT=4000

# Origens permitidas (frontend Vite)
ALLOWED_ORIGINS=http://localhost:4321,http://localhost:5173

# MongoDB — quando definido, o servidor persiste de verdade (fonte única).
# Sem isso, roda com fallback em memória (dados não persistem entre reinícios).
# Ex.: mongodb+srv://usuario:senha@cluster.mongodb.net/portal-implantacao
MONGODB_URI=

# Segredo para assinar os tokens de login (JWT). Use uma frase longa e aleatória.
JWT_SECRET=troque-por-uma-frase-longa-e-aleatoria
JWT_EXPIRES_IN=7d

# ─── E-mail (Resend / HTTP) — envia o código de verificação no cadastro ───
# Usamos Resend (resend.com) porque o Render bloqueia SMTP. Sem a chave, o
# código só fica no log (e, em dev, aparece na tela).
#   RESEND_API_KEY = a API key do Resend (começa com re_)
#   MAIL_FROM      = remetente. Sem domínio verificado no Resend, use
#                    "Portal Nairuz <onboarding@resend.dev>" (entrega só para o
#                    e-mail da sua conta Resend). Verifique nairuz.com.br no
#                    Resend para enviar a qualquer destinatário.
RESEND_API_KEY=
MAIL_FROM=Portal Nairuz <onboarding@resend.dev>

# ─── Automação de criação de projetos com a Naira ───
# Em development, o default é mock; em produção, disabled. O modo HTTP nunca
# cai silenciosamente para mock quando há falha.
NAIRA_MODE=
# URL base privada: o adaptador chama POST {NAIRA_BASE_URL}/imports.
NAIRA_BASE_URL=
# Segredo enviado somente pelo backend como Authorization: Bearer.
NAIRA_API_KEY=
# URL pública deste painel que a Naira chama ao terminar uma análise assíncrona.
NAIRA_CALLBACK_URL=http://localhost:4000/api/integrations/naira/callback
# Segredo compartilhado para X-Naira-Signature (HMAC-SHA256 do JSON bruto).
NAIRA_CALLBACK_SECRET=
# Credencial escopada para a Naira enviar rascunhos estruturados ao painel.
NAIRA_M2M_TOKEN=
NAIRA_TIMEOUT_MS=45000
NAIRA_MAX_PDF_BYTES=8388608
NAIRA_MAX_JSON_BYTES=1048576
NAIRA_FILE_RETENTION_HOURS=24
