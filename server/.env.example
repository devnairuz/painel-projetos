# Porta da API
PORT=4000

# Origens permitidas (frontend Vite)
ALLOWED_ORIGINS=http://localhost:4321,http://localhost:5173

# MongoDB — quando definido, o servidor persiste de verdade (fonte única).
# Sem isso, roda com fallback em memória (dados não persistem entre reinícios).
# Ex.: mongodb+srv://usuario:senha@cluster.mongodb.net/portal-implantacao
MONGODB_URI=

# Segredo para assinar os tokens de login (JWT). Use uma frase longa e aleatória.
JWT_SECRET=troque-por-uma-frase-longa-e-aleatoria
JWT_EXPIRES_IN=7d

# ─── E-mail ───
# Envia o código de verificação/reset por e-mail. Sem isto, o código só fica
# logado (e, em dev, aparece na tela).
#
# RECOMENDADO no Render (que BLOQUEIA portas SMTP de saída): Resend (HTTP).
#   1) crie a conta em resend.com e gere uma API key
#   2) RESEND_API_KEY = a chave
#   3) MAIL_FROM = remetente (para testar sem verificar domínio use
#      "Portal Nairuz <onboarding@resend.dev>"; para produção, verifique o
#      domínio nairuz.com.br no Resend e use no-reply@nairuz.com.br)
RESEND_API_KEY=
MAIL_FROM=Portal Nairuz <onboarding@resend.dev>

# Alternativa SMTP (NÃO funciona no Render — porta bloqueada; serve p/ outros
# hosts). Gmail: host smtp.gmail.com, porta 587, secure false, pass = senha de app.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Portal Nairuz <no-reply@nairuz.com.br>
